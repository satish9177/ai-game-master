# LLM room generator provider (real-room-generator-provider v0; ADR-0023)
#
# DEV-ONLY / BYOK. Vite inlines VITE_* values into the built browser bundle, so
# a real key compiled into a production build is exposed to every visitor. Put
# real values in a gitignored .env.local, use them only with `npm run dev`, and
# NEVER `npm run build` and deploy a bundle compiled with a real key. Hosted
# production must move the provider server-side.
#
# Leave these unset (or set provider=fake) to use the deterministic
# FakeRoomGenerator: no key, no network, no cost. The real provider is selected
# ONLY when provider ∈ {openai, deepseek} AND the matching key AND the model are
# all non-empty.

# Provider: fake (default, no key needed) | openai | deepseek
# Anthropic is deferred to a future slice.
VITE_AIGM_LLM_PROVIDER=fake

# Model id — required for a real provider (leave blank for fake).
# Example OpenAI: gpt-4o-mini    Example DeepSeek: deepseek-chat
# Note: some newer OpenAI models require `max_completion_tokens` instead of
# `max_tokens` — a documented follow-up not handled in v0.
VITE_AIGM_LLM_MODEL=

# Bounded output cap (default 2000 tokens) and hard request timeout in ms
# (default 25000). Adjust if your chosen model has stricter limits.
VITE_AIGM_LLM_MAX_TOKENS=2000
VITE_AIGM_LLM_TIMEOUT_MS=25000

# Real-attempt session cap (default 10). When a real provider is active the app
# counts generation attempts against this cap and requires an explicit confirm
# before continuing once the cap is reached. Helps avoid unexpected API costs
# during a demo session. Has no effect when provider=fake.
VITE_AIGM_LLM_SESSION_CAP=10

# Provider-specific API keys. Only the key matching the provider above is used.
# Real providers incur API costs at your provider's standard rates.
VITE_OPENAI_API_KEY=
VITE_DEEPSEEK_API_KEY=

# Reserved for the Anthropic follow-up; unused in v0.
# VITE_ANTHROPIC_API_KEY=
