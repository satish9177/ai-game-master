# LLM room generator provider (real-room-generator-provider v0; ADR-0023)
#
# DEV-ONLY / BYOK. Vite inlines VITE_* values into the built browser bundle, so a
# real key compiled into a production build would ship to every visitor. Put real
# values in a gitignored .env.local, use them only with `npm run dev`, and NEVER
# `npm run build` + deploy a bundle compiled with a real key. Hosted production
# must move the provider server-side later.
#
# Leave these unset (or provider=fake) to use the deterministic FakeRoomGenerator,
# which needs no key and no network. The real provider is selected ONLY when the
# provider is openai|deepseek AND its matching key AND the model are all non-empty.

# Provider: fake (default) | openai | deepseek. Anthropic is deferred.
VITE_AIGM_LLM_PROVIDER=fake

# Model id. Required for a real provider. Choose a chat model that accepts
# `max_tokens` (some newer OpenAI models require `max_completion_tokens` instead —
# a documented follow-up, not handled in v0).
VITE_AIGM_LLM_MODEL=

# Bounded output cap (default 2000) and hard request timeout in ms (default 25000).
VITE_AIGM_LLM_MAX_TOKENS=2000
VITE_AIGM_LLM_TIMEOUT_MS=25000

# Provider-specific API keys (only the one matching the provider above is used).
VITE_OPENAI_API_KEY=
VITE_DEEPSEEK_API_KEY=

# Reserved for the Anthropic follow-up; unused in v0.
# VITE_ANTHROPIC_API_KEY=
